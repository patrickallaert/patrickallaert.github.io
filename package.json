{
  "name": "conexao-be",
  "private": true,
  "version": "0.1.0",
  "description": "Static site rebuild for Conexao",
  "scripts": {
    "build:css": "sass --no-source-map src/styles/site.scss site/assets/theme-classic.css && sass --no-source-map src/styles/new.scss site/assets/theme-new.css && cp site/assets/theme-new.css site/assets/site.css",
    "build": "npm run build:css",
    "lint:css": "stylelint \"src/styles/**/*.scss\"",
    "watch:css": "sass --watch src/styles/site.scss:site/assets/theme-classic.css src/styles/new.scss:site/assets/site.css"
  },
  "devDependencies": {
    "postcss-scss": "^4.0.9",
    "sass": "^1.93.2",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0"
  }
}
